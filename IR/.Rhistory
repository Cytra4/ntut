# install.packages("writexl")
library(tidyverse)
library(haven)
library(psych)
library(writexl)
summer <- read_sav("summersurvey.sav")
summer
glimpse(summer)
#change variable type
# %>% -> then (shortcut: ctrl + shift + m)
# factor -> <fct> -> categorical variable
summer<-summer %>%
mutate(gender = as.factor(gender))
glimpse(summer)
summer<-summer %>%
mutate(Degree = as.factor(Degree))
# install.packages("writexl")
library(tidyverse)
library(haven)
library(psych)
library(writexl)
summer <- read_sav("summersurvey.sav")
summer
glimpse(summer)
#change variable type
# %>% -> then (shortcut: ctrl + shift + m)
# factor -> <fct> -> categorical variable
summer<-summer %>%
mutate(gender = as.factor(gender))
summer<-summer %>%
mutate(Degree = as.factor(Degree))
summer<-summer %>%
mutate(Goal = as.factor(Goal))
summer<-summer %>%
mutate(Attitude = as.factor(Attitude))
summer<-summer %>%
mutate(Excited = as.factor(Excited))
summer<-summer %>%
mutate(Anxious = as.factor(Anxious))
glimpse(summer)
